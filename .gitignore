# =====================================================
# FraudShield-AI .gitignore
# =====================================================

# -----------------------
# Python
# -----------------------
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# -----------------------
# Distribution / Packaging
# -----------------------
.Python
build/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# -----------------------
# Virtual Environments
# -----------------------
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# -----------------------
# Environment Variables
# -----------------------
.env
.envrc

# -----------------------
# Jupyter
# -----------------------
.ipynb_checkpoints/

# -----------------------
# VS Code
# -----------------------
.vscode/
tempCodeRunnerFile.py

# -----------------------
# Testing / Coverage
# -----------------------
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.hypothesis/
coverage.xml
*.cover

# -----------------------
# Type Checking
# -----------------------
.mypy_cache/
.pyre/
.pytype/
.dmypy.json
dmypy.json

# -----------------------
# Ruff
# -----------------------
.ruff_cache/

# -----------------------
# Logs
# -----------------------
*.log
pip-log.txt

# -----------------------
# macOS
# -----------------------
.DS_Store

# -----------------------
# Misc
# -----------------------
.cache/
site/
target/
instance/

# =====================================================
# FraudShield-AI Project
# =====================================================

# Ignore ONLY the original Kaggle dataset
data/raw/


# Ignore generated processed datasets (can be regenerated)
data/processed/

# Keep trained models
# models/

# Ignore TensorFlow checkpoint files
*.ckpt